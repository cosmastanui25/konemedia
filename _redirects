# Dynamic posts-only sitemap (Netlify function), refreshed every 12h
/sitemap.xml    /.netlify/functions/sitemap   200

# Old category URLs -> new clean category URLs (301 for SEO consolidation)
/category/*     /:splat                        301

# SPA fallback: serve the app for every other path with a 200 status
/*              /index.html                    200
